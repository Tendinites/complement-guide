---
import Layout from '../layouts/Layout.astro';
import { articles } from '../data/articles';

const tests = articles.filter(a => a.type === 'test');
---

<Layout
  title="Tests & Avis produits — EDP Nutrition"
  description="Avis et tests de compléments alimentaires par nos experts : composition, efficacité, rapport qualité-prix. Des avis honnêtes et indépendants."
>
  <div class="page container" style="padding:40px 0 80px">
    <h1 style="font-size:40px;font-weight:800;margin-bottom:12px">Tests & Avis</h1>
    <p style="font-size:18px;color:var(--color-text-light);margin-bottom:40px">Avis honnêtes et indépendants sur les compléments alimentaires testés par notre équipe.</p>
    {tests.length > 0 ? (
      <div class="grid-3">
        {tests.map(a => (
          <a href={`/articles/${a.slug}`} class="card">
            <div class="card__body">
              <span class="card__tag">Test & Avis</span>
              <div class="card__title">{a.titre}</div>
              <p class="card__excerpt">{a.extrait}</p>
              <div class="card__meta">
                <span>{a.complement}</span><span>·</span><span>{a.duree}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <p style="color:var(--color-text-light);text-align:center;padding:64px">Nos tests arrivent bientôt !</p>
    )}
  </div>
</Layout>
