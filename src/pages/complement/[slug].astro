---
import Layout from '../../layouts/Layout.astro';
import { articles, complements } from '../../data/articles';

const heroImgs: Record<string, string> = {
  'omega-3':          'https://images.unsplash.com/photo-1519708227418-c8fd9a32b7a2?w=480&h=260&fit=crop&auto=format',
  'magnesium':        'https://images.unsplash.com/photo-1628771065518-0d82f1938462?w=480&h=260&fit=crop&auto=format',
  'vitamine-d':       'https://images.unsplash.com/photo-1469474968028-56623f02e42e?w=480&h=260&fit=crop&auto=format',
  'collagene':        'https://images.unsplash.com/photo-1515377905703-c4788e51af15?w=480&h=260&fit=crop&auto=format',
  'whey':             'https://images.unsplash.com/photo-1593095948071-474c5cc2989d?w=480&h=260&fit=crop&auto=format',
  'creatine':         'https://images.unsplash.com/photo-1517836357463-d25dfeac3438?w=480&h=260&fit=crop&auto=format',
  'probiotiques':     'https://images.unsplash.com/photo-1574316071802-0d684efa7bf5?w=480&h=260&fit=crop&auto=format',
  'multivitamines':   'https://images.unsplash.com/photo-1512069772995-ec65ed45afd6?w=480&h=260&fit=crop&auto=format',
  'ashwagandha':      'https://images.unsplash.com/photo-1542601906990-b4d3fb778b09?w=480&h=260&fit=crop&auto=format',
  'zinc':             'https://images.unsplash.com/photo-1587854692152-cbe660dbde88?w=480&h=260&fit=crop&auto=format',
  'fer':              'https://images.unsplash.com/photo-1490645935967-10de6ba17061?w=480&h=260&fit=crop&auto=format',
};

export async function getStaticPaths() {
  return complements.map(c => ({ params: { slug: c.slug }, props: { complement: c } }));
}

const { complement } = Astro.props;

const complementArticles = articles.filter(a =>
  a.complement.toLowerCase() === complement.nom.toLowerCase() ||
  a.complement === complement.slug
);

const typeLabels: Record<string, string> = {
  comparatif: 'Comparatif',
  conseil: 'Conseil',
  test: 'Test & Avis',
  'code-promo': 'Code Promo',
};

const breadcrumbLD = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: 'https://monsite.fr' },
    { '@type': 'ListItem', position: 2, name: complement.nom },
  ],
};
---

<Layout
  title={complement.seoTitle}
  description={complement.seoDescription}
  jsonLd={breadcrumbLD}
>
  <div class="complement-page">
    <div class="container">

      <!-- Breadcrumb -->
      <nav class="breadcrumb">
        <a href="/">Accueil</a>
        <span>›</span>
        <span>{complement.nom}</span>
      </nav>

      <!-- Hero section -->
      <div class="complement-hero">
        <div class="complement-hero__content">
          <h1 class="complement-hero__title">{complement.nom}</h1>
          <p class="complement-hero__intro">{complement.introText}</p>
        </div>
      </div>

      <!-- Articles de ce complément -->
      <section class="complement-articles">
        <h2 class="section-title">Nos guides sur le {complement.nom}</h2>
        <p class="section-subtitle">{complementArticles.length} article{complementArticles.length > 1 ? 's' : ''} — comparatifs, conseils et tests rédigés par nos experts.</p>

        {complementArticles.length > 0 ? (
          <div class="art-cards">
            {complementArticles.map((article, i) => (
              <a href={`/articles/${article.slug}`} class={`art-card ${i === 0 ? 'art-card--lead' : ''}`}>
                {i === 0 && (
                  <div class="art-card__img-wrap">
                    <img
                      src={heroImgs[complement.slug] ?? heroImgs['multivitamines']}
                      alt={article.titre}
                      loading="lazy"
                      width="480" height="220"
                      class="art-card__img"
                    />
                    <span class={`art-card__badge art-card__badge--${article.type}`}>
                      {typeLabels[article.type] ?? article.type}
                    </span>
                  </div>
                )}
                <div class="art-card__body">
                  {i > 0 && (
                    <span class={`art-card__tag art-card__tag--${article.type}`}>
                      {typeLabels[article.type] ?? article.type}
                    </span>
                  )}
                  <p class="art-card__title">{article.titre}</p>
                  <p class="art-card__excerpt">{article.extrait}</p>
                  <div class="art-card__meta">
                    <span class="art-card__time">⏱ {article.duree}</span>
                    <span class="art-card__read">Lire →</span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        ) : (
          <div class="empty-articles">
            <p>Nos experts rédigent actuellement des guides sur le {complement.nom}. Revenez bientôt !</p>
          </div>
        )}
      </section>

      <!-- Objectifs liés -->
      {complement.objectifs.length > 0 && (
        <section class="related-objectifs">
          <h2 class="section-title">Objectifs liés</h2>
          <div class="pills-row">
            {complement.objectifs.map(obj => (
              <a href={`/objectif/${obj.toLowerCase().replace(/ /g, '-')}`} class="pill">{obj}</a>
            ))}
          </div>
        </section>
      )}

    </div>
  </div>
</Layout>

<style>
.complement-page { padding: 32px 0 80px; }

.complement-hero {
  background: linear-gradient(135deg, #FFF7F5 0%, #F9FAFB 100%);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-card);
  padding: 48px;
  margin-bottom: 56px;
}
.complement-hero__title {
  font-size: 42px;
  font-weight: 800;
  margin-bottom: 20px;
}
.complement-hero__intro {
  font-size: 17px;
  line-height: 1.75;
  color: var(--color-text-body);
  max-width: 720px;
  margin-bottom: 32px;
}
.complement-hero__stats {
  display: flex;
  gap: 24px;
  flex-wrap: wrap;
}
.stat-box {
  background: var(--color-white);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-box);
  padding: 20px 24px;
  min-width: 200px;
}
.stat-box__value {
  font-family: var(--font-heading);
  font-size: 28px;
  font-weight: 800;
  color: var(--color-cta);
}
.stat-box__unit { font-size: 16px; font-weight: 600; color: var(--color-text-light); margin-left: 4px; }
.stat-box__label { font-size: 13px; color: var(--color-text-light); line-height: 1.4; margin-top: 6px; }

@media (max-width: 768px) {
  .complement-hero { padding: 28px 20px; }
  .complement-hero__title { font-size: 30px; }
}

.complement-articles { margin-bottom: 48px; }
.empty-articles {
  background: var(--color-section-bg);
  border-radius: var(--radius-box);
  padding: 40px;
  text-align: center;
  color: var(--color-text-light);
}

.related-objectifs { margin-top: 48px; }
.pills-row { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 16px; }

/* ── CARTES ARTICLES ─────────────────────────────────────────── */
.art-cards {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 16px;
  margin-top: 24px;
}
@media (min-width: 640px) {
  .art-cards { grid-template-columns: 1fr 1fr; }
  .art-card--lead { grid-column: 1 / -1; }
  .art-card--lead .art-card__img-wrap { aspect-ratio: 16/6; }
}
@media (min-width: 860px) {
  .art-cards { grid-template-columns: 1.6fr 1fr 1fr; }
  .art-card--lead { grid-column: 1; grid-row: 1 / span 2; }
  .art-card--lead .art-card__img-wrap { aspect-ratio: 4/3; }
}

.art-card {
  display: flex;
  flex-direction: column;
  background: #fff;
  border: 1px solid #E2E8F0;
  border-radius: 14px;
  overflow: hidden;
  text-decoration: none;
  transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
}
.art-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 8px 28px rgba(0,0,0,0.09);
  border-color: #CBD5E1;
}

.art-card__img-wrap {
  position: relative;
  overflow: hidden;
  aspect-ratio: 16/9;
  flex-shrink: 0;
}
.art-card__img {
  width: 100%; height: 100%;
  object-fit: cover; display: block;
  transition: transform .3s ease;
}
.art-card:hover .art-card__img { transform: scale(1.03); }

.art-card__badge {
  position: absolute; top: 12px; left: 12px;
  font-size: 11px; font-weight: 700;
  font-family: 'Montserrat', sans-serif;
  text-transform: uppercase; letter-spacing: .05em;
  padding: 4px 10px; border-radius: 999px;
}
.art-card__badge--comparatif { background: #3B82F6; color: #fff; }
.art-card__badge--conseil    { background: #10B981; color: #fff; }
.art-card__badge--test       { background: #F59E0B; color: #fff; }

.art-card__body {
  flex: 1; padding: 18px 20px 20px;
  display: flex; flex-direction: column; gap: 8px;
}

.art-card__tag {
  display: inline-block; align-self: flex-start;
  font-size: 11px; font-weight: 700;
  font-family: 'Montserrat', sans-serif;
  text-transform: uppercase; letter-spacing: .05em;
  padding: 3px 9px; border-radius: 999px;
}
.art-card__tag--comparatif { background: #EFF6FF; color: #2563EB; }
.art-card__tag--conseil    { background: #F0FDF4; color: #16A34A; }
.art-card__tag--test       { background: #FFFBEB; color: #B45309; }

.art-card__title {
  font-size: 15px; font-weight: 700;
  font-family: 'Montserrat', sans-serif;
  color: #0F172A; line-height: 1.4; margin: 0;
}
.art-card--lead .art-card__title { font-size: 17px; }

.art-card__excerpt {
  font-size: 13.5px; color: #64748B; line-height: 1.55; margin: 0;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.art-card__meta {
  display: flex; align-items: center;
  justify-content: space-between;
  margin-top: auto; padding-top: 10px;
  border-top: 1px solid #F1F5F9;
}
.art-card__time { font-size: 12px; color: #94A3B8; font-family: 'Montserrat', sans-serif; font-weight: 500; }
.art-card__read { font-size: 12px; font-weight: 700; font-family: 'Montserrat', sans-serif; color: #3B82F6; }
.art-card:hover .art-card__read { color: #2563EB; }
</style>
