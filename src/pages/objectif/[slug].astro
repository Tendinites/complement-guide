---
import Layout from '../../layouts/Layout.astro';
import { articles, complements } from '../../data/articles';

const typeLabels: Record<string, string> = {
  comparatif: 'Comparatif',
  conseil: 'Conseil',
  test: 'Test & Avis',
  'code-promo': 'Code Promo',
};

export async function getStaticPaths() {
  // Collecte tous les objectifs uniques depuis complements + articles
  const objectifsMap = new Map<string, string>(); // slug → label
  for (const c of complements) {
    for (const obj of c.objectifs) {
      objectifsMap.set(obj.toLowerCase().replace(/ /g, '-'), obj);
    }
  }
  for (const a of articles) {
    if (a.objectif) {
      objectifsMap.set(a.objectif.toLowerCase().replace(/ /g, '-'), a.objectif);
    }
  }
  return Array.from(objectifsMap.entries()).map(([slug, label]) => ({
    params: { slug },
    props: { label },
  }));
}

const { slug } = Astro.params;
const { label } = Astro.props;

const matchingArticles = articles.filter(a =>
  (a.objectif?.toLowerCase().replace(/ /g, '-')) === slug
);

const relatedComplements = complements.filter(c =>
  c.objectifs.some(o => o.toLowerCase().replace(/ /g, '-') === slug)
);
---

<Layout
  title={`${label} — Compléments et conseils | Complément Guide`}
  description={`Tous nos guides sur l'objectif "${label}" : comparatifs, conseils d'experts et sélections de compléments alimentaires adaptés.`}
>
  <div class="obj-page">
    <div class="container">

      <nav class="breadcrumb">
        <a href="/">Accueil</a>
        <span>›</span>
        <span>Objectif : {label}</span>
      </nav>

      <div class="obj-hero">
        <h1 class="obj-hero__title">Objectif : {label}</h1>
        <p class="obj-hero__sub">
          {matchingArticles.length} guide{matchingArticles.length !== 1 ? 's' : ''} rédigé{matchingArticles.length !== 1 ? 's' : ''} par nos experts pour vous aider à atteindre cet objectif.
        </p>
      </div>

      {relatedComplements.length > 0 && (
        <section class="obj-complements">
          <h2 class="section-title">Compléments associés</h2>
          <div class="comp-pills">
            {relatedComplements.map(c => (
              <a href={`/complement/${c.slug}`} class="comp-pill">
                <strong>{c.nom}</strong>
                <span>{c.description}</span>
              </a>
            ))}
          </div>
        </section>
      )}

      <section class="obj-articles">
        <h2 class="section-title">
          {matchingArticles.length > 0 ? 'Nos guides' : 'Bientôt disponible'}
        </h2>

        {matchingArticles.length > 0 ? (
          <div class="art-grid">
            {matchingArticles.map(a => (
              <a href={`/articles/${a.slug}`} class="art-card">
                <div class="art-card__body">
                  <span class={`art-card__tag art-card__tag--${a.type}`}>
                    {typeLabels[a.type] ?? a.type}
                  </span>
                  <p class="art-card__title">{a.titre}</p>
                  <p class="art-card__excerpt">{a.extrait}</p>
                  <div class="art-card__meta">
                    <span>⏱ {a.duree}</span>
                    <span class="art-card__read">Lire →</span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        ) : (
          <p class="obj-empty">
            Nos experts préparent des guides sur cet objectif. Revenez bientôt !
          </p>
        )}
      </section>

    </div>
  </div>
</Layout>

<style>
.obj-page { padding: 32px 0 80px; background: #F9FAFB; min-height: 60vh; }

.obj-hero {
  background: linear-gradient(135deg, #F0FDF4 0%, #F9FAFB 100%);
  border: 1px solid #D1FAE5;
  border-radius: 12px;
  padding: 40px 48px;
  margin-bottom: 48px;
}
.obj-hero__title {
  font-size: clamp(28px, 4vw, 40px);
  font-weight: 800;
  font-family: 'Montserrat', sans-serif;
  color: #0F172A;
  margin-bottom: 12px;
}
.obj-hero__sub {
  font-size: 16px;
  color: #6B7280;
  font-family: 'Roboto', sans-serif;
}

.obj-complements { margin-bottom: 48px; }
.comp-pills { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 16px; }
.comp-pill {
  display: flex;
  flex-direction: column;
  gap: 4px;
  background: #fff;
  border: 1px solid #E5E7EB;
  border-radius: 10px;
  padding: 14px 18px;
  text-decoration: none;
  min-width: 180px;
  max-width: 240px;
  transition: border-color .15s, box-shadow .15s;
}
.comp-pill:hover { border-color: #22C55E; box-shadow: 0 2px 10px rgba(34,197,94,.12); }
.comp-pill strong { font-family: 'Montserrat', sans-serif; font-size: 15px; font-weight: 700; color: #0F172A; }
.comp-pill span { font-size: 12px; color: #6B7280; line-height: 1.4; }

.art-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 16px;
  margin-top: 20px;
}
.art-card {
  background: #fff;
  border: 1px solid #E5E7EB;
  border-radius: 12px;
  text-decoration: none;
  display: flex;
  flex-direction: column;
  transition: transform .18s, box-shadow .18s, border-color .18s;
  overflow: hidden;
}
.art-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,.08); border-color: #CBD5E1; }
.art-card__body { padding: 18px 20px 20px; display: flex; flex-direction: column; gap: 8px; flex: 1; }

.art-card__tag {
  display: inline-block; align-self: flex-start;
  font-size: 11px; font-weight: 700;
  font-family: 'Montserrat', sans-serif;
  text-transform: uppercase; letter-spacing: .05em;
  padding: 3px 9px; border-radius: 999px;
}
.art-card__tag--comparatif { background: #EFF6FF; color: #2563EB; }
.art-card__tag--conseil    { background: #F0FDF4; color: #16A34A; }
.art-card__tag--test       { background: #FFFBEB; color: #B45309; }

.art-card__title {
  font-size: 15px; font-weight: 700;
  font-family: 'Montserrat', sans-serif;
  color: #0F172A; line-height: 1.4; margin: 0;
}
.art-card__excerpt {
  font-size: 13.5px; color: #64748B; line-height: 1.55; margin: 0;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
}
.art-card__meta {
  display: flex; align-items: center; justify-content: space-between;
  margin-top: auto; padding-top: 10px;
  border-top: 1px solid #F1F5F9;
  font-size: 12px; color: #94A3B8;
  font-family: 'Montserrat', sans-serif; font-weight: 500;
}
.art-card__read { font-weight: 700; color: #3B82F6; }

.obj-empty {
  background: #fff;
  border: 1px solid #E5E7EB;
  border-radius: 12px;
  padding: 40px;
  text-align: center;
  color: #6B7280;
  font-family: 'Roboto', sans-serif;
}

@media (max-width: 768px) {
  .obj-hero { padding: 28px 20px; }
  .comp-pills { flex-direction: column; }
  .comp-pill { max-width: 100%; }
}
</style>
