---
import Layout from '../layouts/Layout.astro';
import { articles, complements, objectifs } from '../data/articles';

const recentArticles = articles.slice(0, 6);
const comparatifs = articles.filter(a => a.type === 'comparatif').slice(0, 4);

const typeLabels: Record<string, string> = {
  comparatif: 'Comparatif',
  conseil: 'Conseil',
  test: 'Test & Avis',
  'code-promo': 'Code Promo',
};
---

<Layout
  title="EDP Nutrition — Expert français en compléments alimentaires"
  description="Guide indépendant sur les compléments alimentaires : comparatifs, conseils, avis produits. Rédigé par des experts en nutrition pour vous aider à choisir les meilleurs compléments."
>

  <!-- ── Hero ────────────────────────────────────────────────── -->
  <section class="hero">
    <div class="container">
      <div class="hero__inner">
        <div class="hero__badge">Expert Français N°1 sur les compléments alimentaires</div>
        <h1 class="hero__title">Découvrez les compléments alimentaires adaptés à tous vos besoins</h1>
        <p class="hero__subtitle">Comparatifs indépendants, conseils d'experts et avis produits pour vous aider à choisir sans vous tromper.</p>
        <div class="hero__actions">
          <a href="/comparatifs" class="btn btn--primary">Voir nos comparatifs</a>
          <a href="/conseils" class="btn btn--outline">Conseils experts</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Explorer par objectif ──────────────────────────────── -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">Explorer par objectif</h2>
      <p class="section-subtitle">Trouvez les compléments adaptés à votre situation et vos objectifs de santé.</p>
      <div class="objectifs-grid">
        {objectifs.map(obj => (
          <a href={`/objectif/${obj.slug}`} class="objectif-card">
            <span class="objectif-card__icon">{obj.icon}</span>
            <span class="objectif-card__label">{obj.nom}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Comparatifs populaires ─────────────────────────────── -->
  {comparatifs.length > 0 && (
    <section class="section section--gray">
      <div class="container">
        <div class="section-header">
          <div>
            <h2 class="section-title">Nos comparatifs populaires</h2>
            <p class="section-subtitle">Nos sélections des meilleurs compléments par catégorie, mises à jour régulièrement.</p>
          </div>
          <a href="/comparatifs" class="btn btn--outline">Tous les comparatifs</a>
        </div>
        <div class="grid-2">
          {comparatifs.map(article => (
            <a href={`/articles/${article.slug}`} class="card card--horiz">
              <div class="card__body">
                <span class="card__tag">{typeLabels[article.type] ?? article.type}</span>
                <div class="card__title">{article.titre}</div>
                <p class="card__excerpt">{article.extrait}</p>
                <div class="card__meta">
                  <span>{article.complement}</span>
                  <span>·</span>
                  <span>{article.duree}</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ── Répertoire compléments ─────────────────────────────── -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">Notre répertoire de compléments</h2>
      <p class="section-subtitle">Guides complets par type de complément — bienfaits, dosage, formes et meilleures marques.</p>
      <div class="complements-grid">
        {complements.map(c => (
          <a href={`/complement/${c.slug}`} class="complement-card">
            <div class="complement-card__name">{c.nom}</div>
            <p class="complement-card__desc">{c.description}</p>
            <span class="complement-card__cta">Voir le guide →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Derniers articles ──────────────────────────────────── -->
  {recentArticles.length > 0 && (
    <section class="section section--gray">
      <div class="container">
        <div class="section-header">
          <div>
            <h2 class="section-title">Derniers articles</h2>
            <p class="section-subtitle">Conseils, guides et avis publiés récemment par notre équipe.</p>
          </div>
          <a href="/articles" class="btn btn--outline">Tous les articles</a>
        </div>
        <div class="grid-3">
          {recentArticles.map(article => (
            <a href={`/articles/${article.slug}`} class="card">
              <div class="card__body">
                <span class={`card__tag ${article.type === 'conseil' ? 'card__tag--blue' : ''}`}>
                  {typeLabels[article.type] ?? article.type}
                </span>
                <div class="card__title">{article.titre}</div>
                <p class="card__excerpt">{article.extrait}</p>
                <div class="card__meta">
                  <span>{article.complement}</span>
                  <span>·</span>
                  <span>{article.duree}</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ── Notre équipe ───────────────────────────────────────── -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">Notre équipe d'experts</h2>
      <p class="section-subtitle">Tous nos articles sont rédigés et vérifiés par des professionnels formés à la nutrition.</p>
      <div class="team-grid">
        {[
          { nom: 'Sophie Marchand', role: 'Naturopathe certifiée', specialite: 'Micronutrition, immunité, gestion du stress' },
          { nom: 'Thomas Girard', role: 'Coach sportif & Nutritionniste', specialite: 'Nutrition sportive, performance, récupération' },
          { nom: 'Élise Renaud', role: 'Diététicienne-nutritionniste', specialite: 'Alimentation équilibrée, carences, santé féminine' },
        ].map(expert => (
          <div class="expert-card">
            <div class="expert-card__avatar">{expert.nom.split(' ').map(n => n[0]).join('')}</div>
            <div class="expert-card__name">{expert.nom}</div>
            <div class="expert-card__role">{expert.role}</div>
            <p class="expert-card__spec">{expert.specialite}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

</Layout>

<style>
/* Hero */
.hero {
  background: linear-gradient(135deg, #FFF7F5 0%, #F9FAFB 100%);
  padding: 72px 0 64px;
  border-bottom: 1px solid var(--color-border);
}
.hero__inner {
  max-width: 680px;
}
.hero__badge {
  display: inline-block;
  font-family: var(--font-heading);
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: var(--color-cta);
  background: #FFF0EB;
  border: 1px solid #FFD5C8;
  padding: 6px 14px;
  border-radius: var(--radius-pill);
  margin-bottom: 20px;
}
.hero__title {
  font-size: 48px;
  font-weight: 800;
  line-height: 1.1;
  margin-bottom: 20px;
  color: var(--color-text);
}
.hero__subtitle {
  font-size: 18px;
  color: var(--color-text-light);
  line-height: 1.6;
  margin-bottom: 32px;
  max-width: 560px;
}
.hero__actions { display: flex; gap: 12px; flex-wrap: wrap; }

@media (max-width: 768px) {
  .hero { padding: 48px 0; }
  .hero__title { font-size: 32px; }
}

/* Section header avec bouton droite */
.section-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16px;
  margin-bottom: 32px;
}
.section-header .section-title,
.section-header .section-subtitle { margin-bottom: 4px; }

/* Objectifs grid */
.objectifs-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 12px;
}
.objectif-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  padding: 20px 12px;
  background: var(--color-white);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-card);
  text-decoration: none;
  transition: all var(--transition);
  text-align: center;
}
.objectif-card:hover { border-color: var(--color-cta); box-shadow: 0 4px 16px rgba(255,112,67,0.12); transform: translateY(-2px); }
.objectif-card__icon { font-size: 28px; }
.objectif-card__label { font-family: var(--font-heading); font-size: 12px; font-weight: 700; color: var(--color-text); line-height: 1.3; }

@media (max-width: 900px) { .objectifs-grid { grid-template-columns: repeat(4, 1fr); } }
@media (max-width: 480px) { .objectifs-grid { grid-template-columns: repeat(2, 1fr); } }

/* Complements grid */
.complements-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
}
.complement-card {
  background: var(--color-white);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-card);
  padding: 20px;
  text-decoration: none;
  transition: all var(--transition);
}
.complement-card:hover { border-color: var(--color-accent); box-shadow: var(--shadow-hover); transform: translateY(-2px); }
.complement-card__name { font-family: var(--font-heading); font-size: 16px; font-weight: 700; color: var(--color-text); margin-bottom: 6px; }
.complement-card__desc { font-size: 13px; color: var(--color-text-light); line-height: 1.5; margin-bottom: 12px; }
.complement-card__cta { font-size: 13px; font-weight: 600; color: var(--color-accent); }

@media (max-width: 900px) { .complements-grid { grid-template-columns: repeat(3, 1fr); } }
@media (max-width: 640px) { .complements-grid { grid-template-columns: repeat(2, 1fr); } }

/* Expert cards */
.team-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
.expert-card {
  background: var(--color-white);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-card);
  padding: 28px 24px;
  text-align: center;
}
.expert-card__avatar {
  width: 64px;
  height: 64px;
  background: var(--color-cta);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-heading);
  font-size: 20px;
  font-weight: 700;
  margin: 0 auto 14px;
}
.expert-card__name { font-family: var(--font-heading); font-size: 17px; font-weight: 700; color: var(--color-text); margin-bottom: 4px; }
.expert-card__role { font-size: 13px; color: var(--color-text-light); font-weight: 500; margin-bottom: 10px; }
.expert-card__spec { font-size: 13px; color: var(--color-text-light); line-height: 1.5; }

@media (max-width: 768px) { .team-grid { grid-template-columns: 1fr; } }
</style>
