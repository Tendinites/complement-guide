<script>
function scrollCards(id: string, delta: number) {
  const el = document.getElementById(id);
  if (el) el.scrollBy({ left: delta, behavior: 'smooth' });
}

function handleSearch() {
  const val = (document.getElementById('hero-search') as HTMLInputElement)?.value?.trim();
  if (val) window.location.href = `/articles?q=${encodeURIComponent(val)}`;
}

document.getElementById('hero-search')?.addEventListener('keydown', (e) => {
  if ((e as KeyboardEvent).key === 'Enter') handleSearch();
});
</script>
