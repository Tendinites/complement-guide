---
import Layout from '../layouts/Layout.astro';
import { articles, complements, objectifs } from '../data/articles';

const recentArticles = articles.slice(0, 8);
const comparatifs = articles.filter(a => a.type === 'comparatif').slice(0, 6);
const conseils = articles.filter(a => a.type === 'conseil').slice(0, 6);

const typeLabels: Record<string, string> = {
  comparatif: 'Comparatif',
  conseil: 'Conseil',
  test: 'Test & Avis',
  'code-promo': 'Code Promo',
};

// Photos Unsplash pour objectifs (lifestyle)
const objPhotos: Record<string, string> = {
  'Perte de poids':       'https://images.pexels.com/photos/3757954/pexels-photo-3757954.jpeg?auto=compress&cs=tinysrgb&w=300&h=300&fit=crop',
  'Bien vieillir':        'https://images.pexels.com/photos/3831645/pexels-photo-3831645.jpeg?auto=compress&cs=tinysrgb&w=300&h=300&fit=crop',
  'Digestion':            'https://images.pexels.com/photos/1640777/pexels-photo-1640777.jpeg?auto=compress&cs=tinysrgb&w=300&h=300&fit=crop',
  'Stress':               'https://images.pexels.com/photos/3094215/pexels-photo-3094215.jpeg?auto=compress&cs=tinysrgb&w=300&h=300&fit=crop',
  'Nutrition sportive':   'https://images.pexels.com/photos/1552252/pexels-photo-1552252.jpeg?auto=compress&cs=tinysrgb&w=300&h=300&fit=crop',
  'Récupération sportive':'https://images.pexels.com/photos/3757952/pexels-photo-3757952.jpeg?auto=compress&cs=tinysrgb&w=300&h=300&fit=crop',
  'Santé féminine':       'https://images.unsplash.com/photo-1518611012118-696072aa579a?w=300&h=300&fit=crop',
};

// Photos Unsplash pour compléments (produits)
const compPhotos: Record<string, string> = {
  'omega-3':        'https://images.unsplash.com/photo-1519708227418-c8fd9a32b7a2?w=280&h=280&fit=crop',
  'magnesium':      'https://images.unsplash.com/photo-1628771065518-0d82f1938462?w=280&h=280&fit=crop',
  'vitamine-d':     'https://images.unsplash.com/photo-1584308666744-24d5c474f2ae?w=280&h=280&fit=crop',
  'collagene':      'https://images.unsplash.com/photo-1515377905703-c4788e51af15?w=280&h=280&fit=crop',
  'whey':           'https://images.unsplash.com/photo-1593095948071-474c5cc2989d?w=280&h=280&fit=crop',
  'creatine':       'https://images.unsplash.com/photo-1517836357463-d25dfeac3438?w=280&h=280&fit=crop',
  'probiotiques':   'https://images.unsplash.com/photo-1574316071802-0d684efa7bf5?w=280&h=280&fit=crop',
  'multivitamines': 'https://images.unsplash.com/photo-1512069772995-ec65ed45afd6?w=280&h=280&fit=crop',
  'ashwagandha':    'https://images.unsplash.com/photo-1542601906990-b4d3fb778b09?w=280&h=280&fit=crop',
  'zinc':           'https://images.unsplash.com/photo-1587854692152-cbe660dbde88?w=280&h=280&fit=crop',
  'fer':            'https://images.unsplash.com/photo-1558030006-450675393462?w=280&h=280&fit=crop',
};

// Photo spécifique par article (slug) — toutes Pexels, rapport direct avec le sujet
const articleSlugPhotos: Record<string, string> = {
  'ashwagandha-stress-comparatif':      'https://images.pexels.com/photos/3094215/pexels-photo-3094215.jpeg?auto=compress&cs=tinysrgb&w=640&h=400&fit=crop',
  'bain-froid-maison-guide':            'https://images.pexels.com/photos/3737586/pexels-photo-3737586.jpeg?auto=compress&cs=tinysrgb&w=640&h=400&fit=crop',
  'bottes-compression-comparatif':      'https://images.pexels.com/photos/1598505/pexels-photo-1598505.jpeg?auto=compress&cs=tinysrgb&w=640&h=400&fit=crop',
  'collagene-marin-comparatif':         'https://images.pexels.com/photos/3737586/pexels-photo-3737586.jpeg?auto=compress&cs=tinysrgb&w=640&h=400&fit=crop',
  'creatine-guide-complet':             'https://images.pexels.com/photos/1552252/pexels-photo-1552252.jpeg?auto=compress&cs=tinysrgb&w=640&h=400&fit=crop',
  'cryotherapie-bain-froid-guide':      'https://images.pexels.com/photos/3764013/pexels-photo-3764013.jpeg?auto=compress&cs=tinysrgb&w=640&h=400&fit=crop',
  'electrostimulation-ems-comparatif':  'https://images.pexels.com/photos/3757954/pexels-photo-3757954.jpeg?auto=compress&cs=tinysrgb&w=640&h=400&fit=crop',
  'fer-carence-femme':                  'https://images.pexels.com/photos/3768916/pexels-photo-3768916.jpeg?auto=compress&cs=tinysrgb&w=640&h=400&fit=crop',
  'foam-roller-guide':                  'https://images.pexels.com/photos/3757952/pexels-photo-3757952.jpeg?auto=compress&cs=tinysrgb&w=640&h=400&fit=crop',
  'magnesium-bisglycinate-guide':       'https://images.pexels.com/photos/3807517/pexels-photo-3807517.jpeg?auto=compress&cs=tinysrgb&w=640&h=400&fit=crop',
  'multivitamines-guide':               'https://images.pexels.com/photos/3683074/pexels-photo-3683074.jpeg?auto=compress&cs=tinysrgb&w=640&h=400&fit=crop',
  'omega-3-epa-vs-dha-quelles-differences-et-lequel-pren': 'https://images.pexels.com/photos/3872374/pexels-photo-3872374.jpeg?auto=compress&cs=tinysrgb&w=640&h=400&fit=crop',
  'omega-3-meilleur-complement':        'https://images.pexels.com/photos/3850834/pexels-photo-3850834.jpeg?auto=compress&cs=tinysrgb&w=640&h=400&fit=crop',
  'omega-3-omega-3-et-inflammation-chronique-ce-que-dise': 'https://images.pexels.com/photos/4386467/pexels-photo-4386467.jpeg?auto=compress&cs=tinysrgb&w=640&h=400&fit=crop',
  'pistolet-massage-comparatif':        'https://images.pexels.com/photos/3865557/pexels-photo-3865557.jpeg?auto=compress&cs=tinysrgb&w=640&h=400&fit=crop',
  'probiotiques-comparatif':            'https://images.pexels.com/photos/1640777/pexels-photo-1640777.jpeg?auto=compress&cs=tinysrgb&w=640&h=400&fit=crop',
  'vitamine-d3-k2-comparatif':          'https://images.pexels.com/photos/3822622/pexels-photo-3822622.jpeg?auto=compress&cs=tinysrgb&w=640&h=400&fit=crop',
  'whey-proteine-comparatif':           'https://images.pexels.com/photos/3768916/pexels-photo-3768916.jpeg?auto=compress&cs=tinysrgb&w=640&h=400&fit=crop',
  'zinc-immunite-guide':                'https://images.pexels.com/photos/3807530/pexels-photo-3807530.jpeg?auto=compress&cs=tinysrgb&w=640&h=400&fit=crop',
  // Articles matériel de récupération — slugs principaux
  'pistolet-massage':                   'https://images.pexels.com/photos/5327481/pexels-photo-5327481.jpeg?auto=compress&cs=tinysrgb&w=640&h=400&fit=crop',
  'bottes-compression':                 'https://images.pexels.com/photos/27730532/pexels-photo-27730532.jpeg?auto=compress&cs=tinysrgb&w=640&h=400&fit=crop',
  'foam-roller':                        'https://images.pexels.com/photos/4378850/pexels-photo-4378850.jpeg?auto=compress&cs=tinysrgb&w=640&h=400&fit=crop',
  'electrostimulation':                 'https://images.pexels.com/photos/13185368/pexels-photo-13185368.jpeg?auto=compress&cs=tinysrgb&w=640&h=400&fit=crop',
  'cryotherapie':                       'https://images.pexels.com/photos/14815629/pexels-photo-14815629.jpeg?auto=compress&cs=tinysrgb&w=640&h=400&fit=crop',
  'bain-froid':                         'https://images.pexels.com/photos/14815624/pexels-photo-14815624.jpeg?auto=compress&cs=tinysrgb&w=640&h=400&fit=crop',
};

// Photo pour articles (par slug d'abord, sinon par complément)
const articlePhoto = (slug: string, complement: string) => {
  if (articleSlugPhotos[slug]) return articleSlugPhotos[slug];
  const base = compPhotos[complement] || 'https://images.unsplash.com/photo-1512069772995-ec65ed45afd6?w=640&h=400&fit=crop';
  return base.replace('w=280&h=280', 'w=640&h=400');
};
---

<Layout
  title="Complément Guide — Expert français en compléments alimentaires"
  description="Guide indépendant sur les compléments alimentaires : comparatifs, conseils, avis produits. Rédigé par des experts en nutrition pour vous aider à choisir les meilleurs compléments."
>

  <!-- ═══════════════════════════════════════════════════════════
       HERO — dark gradient EDP
       ══════════════════════════════════════════════════════════ -->
  <section class="edp-hero">
    <div class="edp-hero-inner">
      <h1>Le guide indépendant des<br/><span>compléments alimentaires</span></h1>
      <p class="edp-hero-sub">
        Comparatifs honnêtes, conseils d'experts et avis produits.<br/>
        <u>Tout ce qu'il faut savoir pour bien choisir, sans se tromper.</u>
      </p>

      <div class="edp-search-wrap">
        <div class="edp-search-bar">
          <input
            type="text"
            id="hero-search"
            placeholder="Rechercher un complément, un objectif…"
            autocomplete="off"
            aria-label="Rechercher"
          />
          <button type="button" onclick="handleSearch()">Rechercher</button>
        </div>
        <div class="edp-search-dropdown" id="search-dropdown"></div>
      </div>

      <p class="edp-search-examples">Ex : oméga 3, magnésium, sommeil, sport, immunité…</p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       OBJECTIFS — scroll horizontal, cartes photos
       ══════════════════════════════════════════════════════════ -->
  <section class="edp-objectives">
    <div class="edp-objectives-container">
      <div class="edp-obj-title">LES COMPLÉMENTS SELON VOS OBJECTIFS</div>
      <div class="edp-objectives-scroll" id="obj-scroll">
        {objectifs.map(obj => (
          <a href={`/articles?objectif=${obj.slug}`} class="edp-obj-item">
            <div class="edp-obj-img">
              <img
                src={objPhotos[obj.nom] ?? `https://images.unsplash.com/photo-1512069772995-ec65ed45afd6?w=300&h=300&fit=crop`}
                alt={obj.nom}
                loading="lazy"
                width="150"
                height="150"
              />
            </div>
            <span class="edp-obj-label">{obj.nom}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════
       TOP 10 COMPARATIFS — cartes visuelles + CTA
       ══════════════════════════════════════════════════════════ -->
  <div class="edp-section edp-top10-section">
    <div class="edp-section-header">
      <div class="edp-section-title">NOS TOP 10 COMPARATIFS</div>
      <a href="/comparatifs" class="btn btn--outline">Tous les comparatifs →</a>
    </div>
    <hr class="edp-section-sep" />

    <div class="edp-top10-category-label">💊 Compléments alimentaires</div>
    <div class="edp-top10-grid">
      {[
        { slug: 'complement/whey',           nom: 'Top 10 Whey Protéine',       desc: 'Les meilleures poudres de protéines testées', emoji: '💪', color: '#ECFDF5', border: '#A7F3D0' },
        { slug: 'complement/collagene',      nom: 'Top 10 Collagène',           desc: 'Collagène marin vs bovin : notre classement', emoji: '✨', color: '#FDF4FF', border: '#E9D5FF' },
        { slug: 'complement/omega-3',        nom: 'Top 10 Oméga 3',             desc: 'EPA/DHA : les capsules les plus biodisponibles', emoji: '🐟', color: '#ECFDF5', border: '#A7F3D0' },
        { slug: 'complement/magnesium',      nom: 'Top 10 Magnésium',           desc: 'Bisglycinate, malate : quelle forme choisir ?', emoji: '⚡', color: '#FFFBEB', border: '#FCD34D' },
        { slug: 'complement/vitamine-d',     nom: 'Top 10 Vitamine D',          desc: 'D3 + K2 : les associations les plus efficaces', emoji: '☀️', color: '#FFF7ED', border: '#FED7AA' },
        { slug: 'complement/probiotiques',   nom: 'Top 10 Probiotiques',        desc: 'Flore intestinale : les souches qui fonctionnent', emoji: '🦠', color: '#F0FDF4', border: '#BBF7D0' },
      ].map(item => (
        <a href={`/${item.slug}`} class="edp-top10-card" style={`--card-bg:${item.color};--card-border:${item.border}`}>
          <div class="edp-top10-emoji">{item.emoji}</div>
          <div class="edp-top10-body">
            <div class="edp-top10-name">{item.nom}</div>
            <div class="edp-top10-desc">{item.desc}</div>
          </div>
          <span class="edp-top10-arrow">›</span>
        </a>
      ))}
    </div>

    <div class="edp-top10-category-label" style="margin-top:2rem">🏃 Appareils de récupération</div>
    <div class="edp-top10-grid">
      {[
        { slug: 'articles/pistolet-massage',    nom: 'Top 10 Pistolets massage',    desc: 'Les meilleures percussions musculaires testées', emoji: '🔫', color: '#ECFDF5', border: '#A7F3D0' },
        { slug: 'articles/bottes-compression',  nom: 'Top 10 Bottes compression',   desc: 'Récupération jambes : les meilleurs modèles', emoji: '🥾', color: '#FDF4FF', border: '#E9D5FF' },
        { slug: 'articles/cryotherapie',        nom: 'Top 10 Cryothérapie',         desc: 'Bain froid, cryo locale : notre classement', emoji: '🧊', color: '#ECFDF5', border: '#A7F3D0' },
        { slug: 'articles/foam-roller',         nom: 'Top 10 Foam Rollers',         desc: 'Lisses, vibrants, picots : quelle forme choisir ?', emoji: '🪵', color: '#FFFBEB', border: '#FCD34D' },
        { slug: 'articles/electrostimulation',  nom: 'Top 10 Électrostimulation',   desc: 'EMS & TENS : les appareils qui fonctionnent', emoji: '⚡', color: '#FFF7ED', border: '#FED7AA' },
        { slug: 'articles/bain-froid',          nom: 'Top 10 Bains froids',         desc: 'Tonneaux, baignoires, plonges : notre comparatif', emoji: '🛁', color: '#F0FDF4', border: '#BBF7D0' },
      ].map(item => (
        <a href={`/${item.slug}`} class="edp-top10-card" style={`--card-bg:${item.color};--card-border:${item.border}`}>
          <div class="edp-top10-emoji">{item.emoji}</div>
          <div class="edp-top10-body">
            <div class="edp-top10-name">{item.nom}</div>
            <div class="edp-top10-desc">{item.desc}</div>
          </div>
          <span class="edp-top10-arrow">›</span>
        </a>
      ))}
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════════
       DERNIERS ARTICLES — grille 3 colonnes avec photos
       ══════════════════════════════════════════════════════════ -->
  {recentArticles.length > 0 && (
    <div class="edp-section edp-latest-section">
      <div class="edp-section-header">
        <div class="edp-section-title">DERNIERS ARTICLES</div>
        <div style="display:flex; align-items:center; gap:12px;">
          <div class="edp-scroll-arrows">
            <button class="edp-scroll-btn" onclick="scrollCards('latest-scroll', -380)" aria-label="Précédent">‹</button>
            <button class="edp-scroll-btn" onclick="scrollCards('latest-scroll', 380)" aria-label="Suivant">›</button>
          </div>
          <a href="/articles" class="btn btn--outline">Tous les articles →</a>
        </div>
      </div>
      <hr class="edp-section-sep" />
      <div class="edp-latest-scroll" id="latest-scroll">
        {recentArticles.map(article => (
          <a href={`/articles/${article.slug}`} class="edp-latest-card">
            <div class="edp-latest-img">
              <img
                src={articlePhoto(article.slug, article.complement)}
                alt={article.titre}
                loading="lazy"
                width="360"
                height="220"
              />
              <span class="edp-latest-tag">{typeLabels[article.type] ?? article.type}</span>
            </div>
            <div class="edp-latest-body">
              <h3>{article.titre}</h3>
              <p class="edp-latest-meta">{article.complement} · {article.duree}</p>
              <p class="edp-latest-date">{new Date(article.date).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  )}


  <!-- ═══════════════════════════════════════════════════════════
       RÉPERTOIRE — scroll horizontal, cartes photos rondes
       ══════════════════════════════════════════════════════════ -->
  <div class="edp-section">
    <div class="edp-section-header">
      <div class="edp-section-title">NOTRE RÉPERTOIRE DE COMPLÉMENTS</div>
      <div class="edp-scroll-arrows">
        <button class="edp-scroll-btn" onclick="scrollCards('rep-scroll', -360)" aria-label="Précédent">‹</button>
        <button class="edp-scroll-btn" onclick="scrollCards('rep-scroll', 360)" aria-label="Suivant">›</button>
      </div>
    </div>
    <hr class="edp-section-sep" />
    <div class="edp-rep-scroll" id="rep-scroll">
      {complements.map(c => (
        <a href={`/complement/${c.slug}`} class="edp-rep-item">
          <div class="edp-rep-visual">
            <img
              src={compPhotos[c.slug] ?? 'https://images.unsplash.com/photo-1512069772995-ec65ed45afd6?w=280&h=280&fit=crop'}
              alt={c.nom}
              loading="lazy"
              width="140"
              height="140"
            />
          </div>
          <div class="edp-rep-label">{c.nom}</div>
        </a>
      ))}
    </div>
  </div>


  <!-- ═══════════════════════════════════════════════════════════
       ÉDITÉ PAR DES SPÉCIALISTES
       ══════════════════════════════════════════════════════════ -->
  <section class="edp-specialists">
    <div class="edp-specialists-inner">
      <div class="edp-specialists-badge">✓ Édité par des spécialistes en nutrition</div>
      <p>Tous nos contenus sont rédigés et validés par des naturopathes, diététiciens et coachs sportifs certifiés.</p>
      <a href="/qui-sommes-nous" class="btn btn--blue" style="margin-top:16px;">Notre équipe d'experts →</a>
    </div>
  </section>

</Layout>

<style>
/* ── HERO ─────────────────────────────────────────────────────── */
.edp-hero {
  background: linear-gradient(135deg, #0D1F16 0%, #1C3826 50%, #1A5C3A 100%);
  padding: 80px 24px 90px;
  text-align: center;
  position: relative;
  overflow: visible;
  max-width: 100%;
}
.edp-hero::before {
  content: '';
  position: absolute;
  top: -40%; left: -30%;
  width: 160%; height: 180%;
  background: radial-gradient(ellipse at 30% 50%, rgba(16,185,129,.12) 0%, transparent 55%);
  pointer-events: none;
}
.edp-hero-inner {
  max-width: 760px;
  margin: 0 auto;
  position: relative;
  z-index: 1;
}
.edp-hero h1 {
  font-size: clamp(28px, 4.5vw, 42px);
  font-weight: 800;
  line-height: 1.2;
  margin-bottom: 16px;
  color: #fff;
  font-family: 'Montserrat', sans-serif;
}
.edp-hero h1 span { color: #86EFAC; }
.edp-hero-sub {
  font-size: 17px;
  color: rgba(255,255,255,.65);
  margin-bottom: 34px;
  max-width: 580px;
  margin-left: auto;
  margin-right: auto;
  font-family: 'Roboto', sans-serif;
}
.edp-hero-sub u { text-decoration: underline; text-underline-offset: 3px; }

/* Search */
.edp-search-wrap {
  max-width: 580px;
  margin: 0 auto;
  position: relative;
}
.edp-search-bar {
  display: flex;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 4px 24px rgba(0,0,0,.2);
}
.edp-search-bar input {
  flex: 1;
  padding: 17px 22px;
  font-size: 16px;
  font-family: 'Montserrat', sans-serif;
  border: none;
  outline: none;
  background: #fff;
  color: #1A1A1A;
  min-width: 0;
}
.edp-search-bar input::placeholder { color: #9CA3AF; }
.edp-search-bar button {
  padding: 17px 28px;
  font-size: 15px;
  font-weight: 600;
  font-family: 'Montserrat', sans-serif;
  border: none;
  cursor: pointer;
  background: #22C55E;
  color: #fff;
  transition: background .2s;
  white-space: nowrap;
  flex-shrink: 0;
}
.edp-search-bar button:hover { background: #16A34A; }
.edp-search-dropdown {
  display: none;
  position: absolute;
  top: 100%; left: 0; right: 0;
  background: #fff;
  border-radius: 0 0 12px 12px;
  box-shadow: 0 8px 24px rgba(0,0,0,.15);
  max-height: 360px;
  overflow-y: auto;
  z-index: 100;
}
.edp-search-dropdown.active { display: block; }
.edp-search-examples {
  font-size: 14px;
  color: rgba(255,255,255,.4);
  margin-top: 18px;
  font-family: 'Roboto', sans-serif;
}

/* ── OBJECTIFS ────────────────────────────────────────────────── */
.edp-objectives {
  padding: 32px 0 0;
  background: #fff;
  border-bottom: 1px solid #E5E7EB;
  overflow: hidden;
}
.edp-objectives-container {
  max-width: 1060px;
  margin: 0 auto;
  padding: 0 24px 28px;
}
.edp-obj-title {
  font-size: 22px;
  font-weight: 700;
  text-transform: uppercase;
  color: #1A1A1A;
  margin-bottom: 20px;
  font-family: 'Montserrat', sans-serif;
}
.edp-objectives-scroll {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 16px;
  padding: 8px 0 12px;
}
.edp-obj-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
  text-decoration: none;
  transition: transform .15s;
}
.edp-obj-item:hover { transform: translateY(-3px); }
.edp-obj-img {
  width: 100%;
  aspect-ratio: 1;
  border-radius: 16px;
  background: #F6F7F8;
  border: 2px solid #E5E7EB;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  transition: border-color .2s, box-shadow .2s;
}
.edp-obj-item:hover .edp-obj-img {
  border-color: #22C55E;
  box-shadow: 0 4px 16px rgba(59,130,246,.15);
}
