---
import Layout from '../layouts/Layout.astro';
import { articles } from '../data/articles';

const conseils = articles.filter(a => a.type === 'conseil');
---

<Layout
  title="Conseils nutrition et compléments alimentaires — EDP Nutrition"
  description="Guides pratiques, conseils d'experts et réponses aux questions fréquentes sur les compléments alimentaires : dosage, formes, interactions et bienfaits prouvés."
>
  <div class="page container" style="padding:40px 0 80px">
    <h1 style="font-size:40px;font-weight:800;margin-bottom:12px">Conseils</h1>
    <p style="font-size:18px;color:var(--color-text-light);margin-bottom:40px">Guides pratiques et réponses d'experts sur les compléments alimentaires.</p>
    {conseils.length > 0 ? (
      <div class="grid-3">
        {conseils.map(a => (
          <a href={`/articles/${a.slug}`} class="card">
            <div class="card__body">
              <span class="card__tag card__tag--blue">Conseil</span>
              <div class="card__title">{a.titre}</div>
              <p class="card__excerpt">{a.extrait}</p>
              <div class="card__meta">
                <span>{a.complement}</span><span>·</span><span>{a.duree}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <p style="color:var(--color-text-light);text-align:center;padding:64px">Nos conseils arrivent bientôt !</p>
    )}
  </div>
</Layout>
