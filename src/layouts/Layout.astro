---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Analytics from '@vercel/analytics/astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
  canonicalOverride?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = "Complément Guide — Expert indépendant en compléments alimentaires",
  description = "Guide indépendant sur les compléments alimentaires : comparatifs honnêtes, conseils d'experts et avis produits. Tout ce qu'il faut savoir pour bien choisir.",
  ogImage = "/images/og-default.jpg",
  ogType = 'website',
  noindex = false,
  canonicalOverride,
  jsonLd,
} = Astro.props;

const SITE_URL = 'https://complement-guide.vercel.app';
const canonicalURL = canonicalOverride
  ? new URL(canonicalOverride, SITE_URL).href
  : new URL(Astro.url.pathname, SITE_URL).href;
const ogImageURL = new URL(ogImage, SITE_URL).href;

const organizationLD = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Complément Guide',
  url: SITE_URL,
  logo: `${SITE_URL}/favicon.svg`,
  description: "Guide indépendant sur les compléments alimentaires.",
};

const websiteLD = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Complément Guide',
  url: SITE_URL,
  inLanguage: 'fr-FR',
  potentialAction: {
    '@type': 'SearchAction',
    target: `${SITE_URL}/?s={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
};

const allJsonLd: Record<string, unknown>[] = [organizationLD, websiteLD];
if (jsonLd) {
  if (Array.isArray(jsonLd)) allJsonLd.push(...jsonLd);
  else allJsonLd.push(jsonLd);
}
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {!noindex && <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />}

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content="Complément Guide" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <meta name="theme-color" content="#10B981" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" type="image/x-icon" href="/favicon.ico" />

    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    {allJsonLd.map((data) => (
      <script type="application/ld+json" set:html={JSON.stringify(data)} />
    ))}
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <Analytics />
  </body>
</html>
