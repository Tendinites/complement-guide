---
const nav = [
  {
    label: 'Compléments',
    items: [
      { href: '/complement/omega-3',        label: 'Oméga 3',        emoji: '🐟' },
      { href: '/complement/whey',           label: 'Whey',           emoji: '💪' },
      { href: '/complement/magnesium',      label: 'Magnésium',      emoji: '⚡' },
      { href: '/complement/creatine',       label: 'Créatine',       emoji: '🏋️' },
      { href: '/complement/vitamine-d',     label: 'Vitamine D',     emoji: '☀️' },
      { href: '/complement/probiotiques',   label: 'Probiotiques',   emoji: '🦠' },
      { href: '/complement/collagene',      label: 'Collagène',      emoji: '✨' },
      { href: '/complement/ashwagandha',    label: 'Ashwagandha',    emoji: '🌿' },
      { href: '/complement/multivitamines', label: 'Multivitamines', emoji: '💊' },
      { href: '/complement/zinc',           label: 'Zinc',           emoji: '🛡️' },
      { href: '/complement/fer',            label: 'Fer',            emoji: '🩸' },
    ],
  },
  {
    label: 'Récupération',
    items: [
      { href: '/articles/pistolet-massage',   label: 'Pistolets massage',   emoji: '🔫' },
      { href: '/articles/bottes-compression', label: 'Bottes compression',  emoji: '🥾' },
      { href: '/articles/bain-froid',         label: 'Bain froid',          emoji: '🧊' },
      { href: '/articles/foam-roller',        label: 'Foam roller',         emoji: '🪵' },
      { href: '/articles/electrostimulation', label: 'Électrostimulation',  emoji: '⚡' },
      { href: '/articles/cryotherapie',       label: 'Cryothérapie',        emoji: '❄️' },
    ],
  },
  { label: 'Comparatifs', href: '/comparatifs' },
  { label: 'Conseils', href: '/conseils' },
  { label: 'Articles', href: '/articles' },
];
---

<header class="site-header">
  <div class="header-inner">
    <!-- Logo -->
    <a href="/" class="header-logo" aria-label="Accueil">
      <span class="logo-text">Complément<span class="logo-accent">Guide</span></span>
    </a>

    <!-- Nav desktop -->
    <nav class="header-nav" aria-label="Navigation principale">
      {nav.map(item => (
        item.items ? (
          <div class="nav-dropdown">
            <button class="nav-btn" aria-haspopup="true" aria-expanded="false">
              {item.label}
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class="dropdown-menu">
              {item.items.map(sub => (
                <a href={sub.href} class="dropdown-item">
                  {sub.emoji && <span class="dropdown-emoji">{sub.emoji}</span>}
                  {sub.label}
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a href={item.href} class="nav-link">{item.label}</a>
        )
      ))}
    </nav>

    <!-- Burger mobile -->
    <button class="burger" id="burger-btn" aria-label="Ouvrir le menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <div class="mobile-menu__inner">
      <div class="mobile-section-label">💊 Compléments</div>
      <a href="/complement/omega-3"        class="mobile-link">🐟 Oméga 3</a>
      <a href="/complement/whey"           class="mobile-link">💪 Whey</a>
      <a href="/complement/magnesium"      class="mobile-link">⚡ Magnésium</a>
      <a href="/complement/creatine"       class="mobile-link">🏋️ Créatine</a>
      <a href="/complement/vitamine-d"     class="mobile-link">☀️ Vitamine D</a>
      <a href="/complement/probiotiques"   class="mobile-link">🦠 Probiotiques</a>
      <a href="/complement/collagene"      class="mobile-link">✨ Collagène</a>
      <a href="/complement/ashwagandha"    class="mobile-link">🌿 Ashwagandha</a>
      <a href="/complement/multivitamines" class="mobile-link">💊 Multivitamines</a>
      <a href="/complement/zinc"           class="mobile-link">🛡️ Zinc</a>
      <a href="/complement/fer"            class="mobile-link">🩸 Fer</a>
      <hr class="mobile-menu__sep" />
      <div class="mobile-section-label">🏃 Récupération</div>
      <a href="/articles/pistolet-massage"   class="mobile-link">🔫 Pistolets massage</a>
      <a href="/articles/bottes-compression" class="mobile-link">🥾 Bottes compression</a>
      <a href="/articles/bain-froid"         class="mobile-link">🧊 Bain froid</a>
      <a href="/articles/foam-roller"        class="mobile-link">🪵 Foam roller</a>
      <a href="/articles/electrostimulation" class="mobile-link">⚡ Électrostimulation</a>
      <a href="/articles/cryotherapie"       class="mobile-link">❄️ Cryothérapie</a>
      <hr class="mobile-menu__sep" />
      <a href="/comparatifs" class="mobile-link">Comparatifs</a>
      <a href="/conseils"    class="mobile-link">Conseils</a>
      <a href="/articles"    class="mobile-link">Tous les articles</a>
    </div>
  </div>
</header>

<style>
.site-header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: #1E293B;
  box-shadow: 0 1px 0 rgba(255,255,255,0.06);
}
.header-inner {
  max-width: 1060px;
  margin: 0 auto;
  padding: 0 24px;
  display: flex;
  align-items: center;
  gap: 32px;
  height: 62px;
}
.header-logo {
  text-decoration: none;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 8px;
}
.logo-icon { font-size: 20px; }
.logo-text {
  font-family: 'Montserrat', sans-serif;
  font-size: 18px;
  font-weight: 800;
  color: #fff;
  letter-spacing: -0.3px;
}
.logo-accent { color: #60A5FA; }

.header-nav {
  display: flex;
  align-items: center;
  gap: 2px;
  flex: 1;
}
.nav-link {
  font-family: 'Montserrat', sans-serif;
  font-size: 14px;
  font-weight: 500;
  color: rgba(255,255,255,0.75);
  padding: 8px 12px;
  border-radius: 6px;
  transition: color 0.15s, background 0.15s;
  text-decoration: none;
  white-space: nowrap;
}
.nav-link:hover { color: #fff; background: rgba(255,255,255,0.08); }

.nav-dropdown { position: relative; }
.nav-btn {
  display: flex;
  align-items: center;
  gap: 5px;
  font-family: 'Montserrat', sans-serif;
  font-size: 14px;
  font-weight: 500;
  color: rgba(255,255,255,0.75);
  background: none;
  border: none;
  padding: 8px 12px;
  border-radius: 6px;
  cursor: pointer;
  transition: color 0.15s, background 0.15s;
  white-space: nowrap;
}
.nav-btn:hover { color: #fff; background: rgba(255,255,255,0.08); }

.dropdown-menu {
  position: absolute;
  top: 100%;
  left: 0;
  background: #fff;
  border: 1px solid #E5E7EB;
  border-radius: 12px;
  box-shadow: 0 8px 32px rgba(0,0,0,0.14);
  /* padding-top couvre le gap entre btn et menu → plus de fermeture accidentelle */
  padding: 8px 8px 8px;
  padding-top: 16px;
  margin-top: -8px; /* remonte le menu pour couvrir le gap */
  min-width: 220px;
  z-index: 200;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2px;
  opacity: 0;
  pointer-events: none;
  transform: translateY(-4px);
  transition: opacity 0.15s ease, transform 0.15s ease;
}
.nav-dropdown:hover .dropdown-menu,
.nav-dropdown:focus-within .dropdown-menu {
  opacity: 1;
  pointer-events: all;
  transform: translateY(0);
}
.dropdown-item {
  display: flex;
  align-items: center;
  gap: 7px;
  font-size: 13.5px;
  font-weight: 500;
  font-family: 'Montserrat', sans-serif;
  color: #374151;
  padding: 9px 12px;
  border-radius: 8px;
  text-decoration: none;
  transition: background 0.1s, color 0.1s;
  white-space: nowrap;
}
.dropdown-item:hover { background: #EFF6FF; color: #3B82F6; }
.dropdown-emoji { font-size: 15px; flex-shrink: 0; }

.burger {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 8px;
  margin-left: auto;
}
.burger span {
  display: block;
  width: 22px;
  height: 2px;
  background: rgba(255,255,255,0.8);
  border-radius: 2px;
  transition: all 0.2s ease;
}

.mobile-menu {
  display: none;
  background: #1E293B;
  border-top: 1px solid rgba(255,255,255,0.08);
}
.mobile-menu.open { display: block; }
.mobile-menu__inner {
  padding: 16px 24px 24px;
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.mobile-section-label {
  font-family: 'Montserrat', sans-serif;
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: #3B82F6;
  padding: 4px 12px;
  margin-bottom: 4px;
}
.mobile-link {
  font-size: 15px;
  font-weight: 500;
  font-family: 'Montserrat', sans-serif;
  color: rgba(255,255,255,0.7);
  padding: 10px 12px;
  border-radius: 8px;
  text-decoration: none;
  transition: background 0.15s, color 0.15s;
}
.mobile-link:hover { background: rgba(255,255,255,0.08); color: #fff; }
.mobile-menu__sep { border: none; border-top: 1px solid rgba(255,255,255,0.1); margin: 8px 0; }

@media (max-width: 900px) {
  .header-nav { display: none; }
  .burger { display: flex; }
}
</style>

<script>
const burgerBtn = document.getElementById('burger-btn');
const mobileMenu = document.getElementById('mobile-menu');
burgerBtn?.addEventListener('click', () => {
  const open = mobileMenu?.classList.toggle('open');
  burgerBtn.setAttribute('aria-expanded', String(open));
  mobileMenu?.setAttribute('aria-hidden', String(!open));
});
</script>
