<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <!-- Brand -->
      <div class="footer-brand">
        <a href="/" class="footer-logo">EDP <span>Nutrition</span></a>
        <p class="footer-tagline">Expert français indépendant sur les compléments alimentaires. Conseils basés sur les preuves scientifiques.</p>
        <p class="footer-contact">
          <a href="mailto:contact@monsite.fr">contact@monsite.fr</a>
        </p>
      </div>

      <!-- Navigation -->
      <div class="footer-col">
        <h3 class="footer-heading">Compléments</h3>
        <ul class="footer-links">
          <li><a href="/complement/omega-3">Oméga 3</a></li>
          <li><a href="/complement/magnesium">Magnésium</a></li>
          <li><a href="/complement/vitamine-d">Vitamine D</a></li>
          <li><a href="/complement/collagene">Collagène</a></li>
          <li><a href="/complement/whey">Whey</a></li>
          <li><a href="/complement/creatine">Créatine</a></li>
          <li><a href="/complement/probiotiques">Probiotiques</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h3 class="footer-heading">Contenus</h3>
        <ul class="footer-links">
          <li><a href="/conseils">Conseils</a></li>
          <li><a href="/comparatifs">Comparatifs</a></li>
          <li><a href="/tests">Tests & Avis</a></li>
          <li><a href="/articles">Tous les articles</a></li>
        </ul>
        <h3 class="footer-heading" style="margin-top:20px">Informations</h3>
        <ul class="footer-links">
          <li><a href="/qui-sommes-nous">Qui sommes-nous</a></li>
          <li><a href="/methodologie">Méthodologie</a></li>
          <li><a href="/mentions-legales">Mentions légales</a></li>
          <li><a href="/confidentialite">Confidentialité</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {new Date().getFullYear()} EDP Nutrition — Tous droits réservés</p>
      <p class="footer-disclaimer">Les informations de ce site sont fournies à titre informatif et ne remplacent pas l'avis d'un professionnel de santé.</p>
    </div>
  </div>
</footer>

<style>
.site-footer {
  background: #1A1A1A;
  color: #9CA3AF;
  padding: 56px 0 32px;
  margin-top: 80px;
}
.footer-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr;
  gap: 48px;
  padding-bottom: 48px;
  border-bottom: 1px solid #2D2D2D;
}
.footer-logo {
  font-family: var(--font-heading);
  font-size: 22px;
  font-weight: 800;
  color: #fff;
  text-decoration: none;
  display: inline-block;
  margin-bottom: 12px;
}
.footer-logo span { color: var(--color-cta); }
.footer-tagline {
  font-size: 14px;
  line-height: 1.65;
  color: #9CA3AF;
  max-width: 280px;
  margin-bottom: 16px;
}
.footer-contact a { color: #9CA3AF; font-size: 14px; }
.footer-contact a:hover { color: #fff; }

.footer-heading {
  font-family: var(--font-heading);
  font-size: 13px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.8px;
  color: #fff;
  margin-bottom: 14px;
}
.footer-links { list-style: none; display: flex; flex-direction: column; gap: 8px; }
.footer-links a {
  font-size: 14px;
  color: #9CA3AF;
  text-decoration: none;
  transition: color var(--transition);
}
.footer-links a:hover { color: var(--color-cta); }

.footer-bottom {
  padding-top: 24px;
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.footer-bottom p { font-size: 13px; color: #6B7280; }
.footer-disclaimer { font-size: 12px; color: #4B5563; }

@media (max-width: 768px) {
  .footer-grid {
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }
  .footer-brand { grid-column: 1 / -1; }
}
@media (max-width: 480px) {
  .footer-grid { grid-template-columns: 1fr; }
}
</style>
